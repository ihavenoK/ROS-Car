<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="test_1_world">
    <!-- 光源 -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- 地面 -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- 导入 Building Editor 创建的 Test_1 墙壁模型 -->
    <include>
      <uri>model://Test_1</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>
  </world>
</sdf>
